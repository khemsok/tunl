{
  "name": "@khemsok/tunl",
  "version": "0.1.6",
  "description": "Terminal focus timer that blocks distracting sites and progressively reveals animated ASCII art",
  "type": "module",
  "bin": {
    "tunl": "./dist/cli.js"
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "bun run src/cli.tsx",
    "dev:noblock": "bun run src/cli.tsx --noblock",
    "dev:reset": "bun run src/cli.tsx --reset",
    "dev:stats": "bun run src/cli.tsx --stats",
    "dev:config": "bun run src/cli.tsx --config",
    "dev:uninstall": "bun run src/cli.tsx --uninstall",
    "build": "bun build src/cli.tsx --outdir dist --target node",
    "prepublishOnly": "bun run build",
    "build:ext": "bun build extension/src/popup/popup.ts --outfile extension/dist/popup.js --target browser && bun build extension/src/background/service-worker.ts --outfile extension/dist/service-worker.js --target browser && bun build extension/src/blocked/blocked.ts --outfile extension/dist/blocked.js --target browser",
    "dev:ext": "bun run build:ext --watch",
    "build:chrome": "cd chrome-extension && bun run build",
    "zip:chrome": "cd chrome-extension && bun run zip"
  },
  "keywords": [
    "terminal",
    "focus",
    "timer",
    "pomodoro",
    "ascii-art",
    "cli",
    "productivity",
    "website-blocker",
    "tui"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@opentui/react": "latest",
    "@opentui/core": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/chrome": "^0.0.287",
    "@types/react": "^19.2.14",
    "typescript": "^5.4"
  }
}
